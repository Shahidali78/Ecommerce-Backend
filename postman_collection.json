{
  "info": {
    "_postman_id": "19af80c5-a7e8-4f75-97c4-52ff26f0efc9",
    "name": "E-Commerce Backend API",
    "description": "Requests for the Java Spring Boot E-Commerce Backend System.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "categoryId",
      "value": "1"
    },
    {
      "key": "productId",
      "value": "1"
    },
    {
      "key": "cartItemId",
      "value": "1"
    },
    {
      "key": "orderId",
      "value": "1"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Demo Customer\",\n  \"email\": \"customer@example.com\",\n  \"password\": \"Secure123!\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code < 300) {",
                  "  pm.collectionVariables.set('token', pm.response.json().accessToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@example.com\",\n  \"password\": \"Secure123!\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('token', pm.response.json().accessToken);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Catalog",
      "item": [
        {
          "name": "List Products",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/products?search=&page=0&size=20"
          }
        },
        {
          "name": "Get Product",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/products/{{productId}}"
          }
        },
        {
          "name": "List Categories",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/categories"
          }
        }
      ]
    },
    {
      "name": "Cart and Orders",
      "item": [
        {
          "name": "Add to Cart",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{productId}},\n  \"quantity\": 1\n}"
            },
            "url": "{{baseUrl}}/api/cart/add"
          }
        },
        {
          "name": "View Cart",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/cart"
          }
        },
        {
          "name": "Remove Cart Item",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/cart/{{cartItemId}}"
          }
        },
        {
          "name": "Place Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shippingAddress\": \"123 Example Street, Example City\"\n}"
            },
            "url": "{{baseUrl}}/api/orders"
          }
        },
        {
          "name": "My Orders",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/orders/my-orders"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics\",\n  \"description\": \"Phones, computers, and accessories\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/categories"
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mechanical Keyboard\",\n  \"description\": \"Hot-swappable mechanical keyboard\",\n  \"price\": 89.99,\n  \"stock\": 25,\n  \"imageUrl\": \"https://example.com/keyboard.jpg\",\n  \"categoryId\": {{categoryId}}\n}"
            },
            "url": "{{baseUrl}}/api/admin/products"
          }
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/admin/users"
          }
        },
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/admin/orders"
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CONFIRMED\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/orders/{{orderId}}/status"
          }
        }
      ]
    }
  ]
}
